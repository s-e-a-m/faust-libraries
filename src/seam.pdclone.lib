declare name "PdClone Faust Library";
declare version "0.1";
declare author "Giuseppe Silvi";
declare license "GPL-3.0";
//
// Faithful Faust clones of Pure Data signal objects, verified line-by-line
// against the Pd source (Miller Puckette). Sibling of seam.cyclone.lib (scy),
// which clones Max/gen~. Prefix: spd.
//
// Di Scipio's idioms (seam.discipio.lib, sds) COMPOSE these primitives; they
// do not re-implement the Pd math. See memory project_pdclone_library_architecture.
//
import("seam.lib");
//================================================= PURE DATA OBJECT CLONES ===
//==============================================================================
spd = library("seam.pdclone.lib");

//--- x_acoustics.c : amplitude <-> decibel converters -------------------------
// Pd's dB is a 100 dB-offset scale: a power of 1.0 maps to 100 dB and silence
// clips to 0 (Pd never outputs -inf). LOGTEN = ln(10), so Pd's
// "100 + 10./LOGTEN*log(f)" is exactly "100 + 10*log10(f)".

//-------------------------------------------------------------- powtodb(p) ---
// powtodb(p) = 100 + 10*log10(p), clipped at >= 0 ; p <= 0 -> 0.
// Pd source x_acoustics.c (powtodb). Used by spd.env.
powtodb(p) = select2(p <= 0.0, max(0.0, 100.0 + 10.0*log10(p)), 0.0);
// process = powtodb;   // powtodb(1) = 100 ; powtodb(0.01) = 80 ; powtodb(0) = 0

//-------------------------------------------------------------- rmstodb(r) ---
// rmstodb(r) = 100 + 20*log10(r), clipped at >= 0 ; r <= 0 -> 0.
rmstodb(r) = select2(r <= 0.0, max(0.0, 100.0 + 20.0*log10(r)), 0.0);
// process = rmstodb;   // rmstodb(1) = 100 ; rmstodb(0) = 0

//-------------------------------------------------------------- dbtopow(d) ---
// dbtopow(d) = 10^((d-100)/10), d clamped to <= 870 ; d <= 0 -> 0.
dbtopow(d) = select2(d <= 0.0, pow(10.0, (min(870.0, d) - 100.0)/10.0), 0.0);
// process = dbtopow;   // dbtopow(100) = 1 ; dbtopow(0) = 0

//-------------------------------------------------------------- dbtorms(d) ---
// dbtorms(d) = 10^((d-100)/20), d clamped to <= 485 ; d <= 0 -> 0.
// Inverse of the (env~ -> powtodb) chain: in the LAR loop, env~ -> dbtorms
// collapses to r = sqrt(Hann-weighted mean-square) = RMS. Pd source x_acoustics.c.
dbtorms(d) = select2(d <= 0.0, pow(10.0, (min(485.0, d) - 100.0)/20.0), 0.0);
// process = dbtorms;   // dbtorms(100) = 1 ; dbtorms(80) = 0.1 ; dbtorms(0) = 0

//--- d_filter.c : hip~ --------------------------------------------------------
//------------------------------------------------------------------ hip(f) ---
// One-pole/one-zero high-pass. Pd sighip_perform (compatibilitylevel > 43):
//   coef   = clip(1 - f*2pi/SR, 0, 1)        (sighip_ft1)
//   w[n]   = x[n] + coef*w[n-1]              (fi.pole(coef))
//   y[n]   = normal*(w[n] - w[n-1])          (fi.zero(1) then *normal)
//   normal = (1 + coef)/2
// DIFFERS from fi.highpass (Butterworth biquad): this is Pd's exact topology.
// NOTE: Pd uses the truncated literal 3.14159 for pi (not M_PI); reproduced
// here so the coefficient is bit-identical to Pd's. f <= 0 gives coef = 1: Pd
// then copies the input verbatim (its coef==1 branch), and the pole-at-1 form
// below is algebraically identical (integrator then differencer) though not
// numerically robust at exact DC -- LAR uses hip~ 100, so coef < 1 always.
hip(f) = fi.pole(coef) : fi.zero(1) : *(normal)
with {
    coef   = 1.0 - f*(2.0*3.14159)/ma.SR : max(0.0) : min(1.0);
    normal = (1.0 + coef)/2.0;
};
// process = hip(100);   // 1-in/1-out DC-blocking loop high-pass (LAR: hip~ 100)

//--- d_ctl.c : env~ -----------------------------------------------------------
//---------------------------------------------------- env(npoints, period) ---
// Hann-weighted RMS-power envelope follower, output in Pd dB (via powtodb).
//
// Pd splits env~ across two rates:
//   * FULL RATE  (env_tilde_perform) accumulates, over an npoints window,
//       result = sum_i buf[i] * x[n-i]^2 ,
//       buf[i] = (1 - cos(2pi*i/npoints)) / npoints    (normalized Hann, sum = 1);
//   * CONTROL RATE (env_tilde_tick, a clock callback every `period` samples)
//       outputs powtodb(result) and HOLDS it until the next tick.
//     (Pd default period = npoints/2.)
//
// The one-line spec is a sliding FIR, held at control rate:
//   env = (_ <: sum(i, npoints, (_@i <: *) * (1-cos(2*3.14159*i/npoints))/npoints))
//         : powtodb : ba.sAndH(ba.pulse(period));
// clear, but sum() unrolls to `npoints` taps -- env(2048,*) takes minutes to compile.
// Pd does NOT do that: env_tilde_perform is OVERLAP-ADD (~L = npoints/period active
// Hann windows, O(L)/sample). We implement the overlap-add below; it is float-exact
// vs the FIR above AND vs the Pd env~ oracle (~4e-6 dB, summation-order rounding only)
// and compiles at env(2048,1024) in ~0.16 s. Derivation + A/B: the plugins/dslar study
// sketch doc/sketch/env_oa.dsp.
//
// Each lane runs a DOWN phase d that reaches 0 at its capture instant (n = off mod
// npoints); the L lanes are staggered by `period`, so their captures union to the
// n = 0 mod period grid -- Pd's control-rate clock. At d==0 the weight hann(k) sits on
// x(n-k), identical to the FIR sum. The step-hold is intrinsic (result changes only at a
// capture) -- the block-kernel behaviour of memory project_pd_vs_faust_block_validation,
// expressed directly. No `ondemand` needed: the win is the overlap-add STRUCTURE, not the
// rate primitive (ondemand stays an optional idiom for the per-hop powtodb).
//
// CONSTRAINT: npoints % period == 0 (integer overlap L). Pd rounds realperiod to a block
// multiple; here require exact divisibility (LAR env~ 2048 -> period 1024, L = 2).
// SR-independence (memory project_discipio_sr_independence) stays a porting concern: the
// C++ deliverable sizes npoints = round(fs*2048/44100) at prepare(fs). Pd uses the
// truncated literal 3.14159 for pi; reproduced. an.* followers do NOT match (rectangular /
// one-pole, 0 dB ref): new code, upstream candidate for GRAME (project_env_upstream_grame).
//
// `period` is explicit (Faust has no arity overloading); Pd's one-arg env~ npoints
// defaults period = npoints/2, so mirror that as env(npoints, npoints/2) at the call site.
env(npoints, period) = sqr : overlapAdd
with {
    sqr(x) = x * x;
    overlapAdd(x2) = ba.sAndH(anyCap, grabbed) : powtodb
    with {
        L          = int(npoints / period);          // overlap factor (LAR: 2048/1024 = 2)
        wrapmod(a) = (a % npoints + npoints) % npoints;
        up         = step ~ _ with { step(c) = (c + 1) % npoints; }; // up(n) = (n+1)%npoints
        d(off)     = wrapmod(off + 1 - up);           // d(off)==0 at n = off (mod npoints)
        hann(p)    = (1.0 - cos((2.0*3.14159*p)/npoints)) / npoints;
        lane(off)  = acc
        with {
            dd     = d(off);
            w      = hann(dd);
            newwin = dd == (npoints - 1);             // first sample of a fresh window
            acc    = step ~ _ with { step(a) = select2(newwin, a + w*x2, w*x2); };
        };
        cap(off)   = d(off) == 0;                     // capture instant for this lane
        anyCap     = par(l, L, cap(l*period)) :> _ > 0;
        grabbed    = par(l, L, lane(l*period) * cap(l*period)) :> _;
    };
};
// process = env(2048, 1024); // LAR nominal: env~ 2048 (period 1024, L=2) -> level in dB
// process = env(64, 32);     // small window used in the doc/sketch A/B

//----------------------------------------------------------- line(ms, x) ---
// Pd source x_time.c (line, control-rate). Help patch: line-help.pd.
// Pd `line` ramps linearly toward its target and EMITS at a grain interval
// (DEFAULTLINEGRAIN = 20 ms), a control-rate staircase; it restarts from the
// current value on each new target (setval). Here ba.line is NOT used: the
// linear interp is rebuilt as Pd's v = setval + min(elapsed/R,1)*(target-setval)
// so the tick values match Pd's tau/R exactly, then sAndH on a 20 ms grain
// pulse imposes the staircase. Same idiom as spd.env (real math + control-rate
// hold). FAUST vs Pd: reproduces the grain staircase to float precision; the
// tick PHASE (Pd aligns ticks to message arrival, this to sample 0) is the
// documented residual, deferred to the block-kernel validation sub-project.
line(ms, x) = cont : ba.sAndH(ba.pulse(20.0 * ma.SR/1000.0))
with {
    R    = ms * ma.SR/1000.0;                 // ramp length in samples
    chg  = x != x';                           // new target
    cont = (loop ~ (_,_)) : (_, !)            // continuous interp; keep v, drop counter
    with {
        loop(v, e) = nv, ne
        with {
            ne = ba.if(chg, 0, e + 1);        // samples elapsed since change (0 at change)
            sv = ba.sAndH(chg, v);            // setval = output frozen at the change instant
            nv = sv + min(ne/R, 1.0) * (x - sv);
        };
    };
};
// process = line(100.0); // 100 ms ramp, 20 ms grain staircase; vs Pd line oracle < 1e-6
